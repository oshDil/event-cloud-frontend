# Local dev (no gateway/ingress yet): each service runs on its own port.
# Set a *_BASE_URL for every service you have running; omit the ones you
# don't (calls to those will fail until that service exists, which is fine).
VITE_EVENTS_BASE_URL=http://localhost:4001
VITE_PROGRAM_BASE_URL=http://localhost:4002
VITE_REGISTER_BASE_URL=http://localhost:4003
VITE_REGISTRATIONS_BASE_URL=http://localhost:4003
VITE_ANALYTICS_BASE_URL=http://localhost:4004

VITE_EVENTS_PATH=/events
VITE_PROGRAM_PATH=/program
VITE_REGISTER_PATH=/register
VITE_REGISTRATIONS_PATH=/registrations
VITE_ANALYTICS_PATH=/analytics

# In production, once services sit behind a Kubernetes Ingress, drop the
# per-service *_BASE_URL overrides above and use a single shared base
# instead (empty = same-origin):
# VITE_API_BASE_URL=
# VITE_EVENTS_PATH=/api/events
# VITE_PROGRAM_PATH=/api/program
# VITE_REGISTER_PATH=/api/register
# VITE_REGISTRATIONS_PATH=/api/registrations
# VITE_ANALYTICS_PATH=/api/analytics
