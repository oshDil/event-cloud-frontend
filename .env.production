# Used by `vite build` (Docker image build stage). Behind the Kubernetes
# Ingress, frontend and API share an origin, so leave the base URL empty and
# route by path prefix instead of per-service ports.
VITE_EVENTS_PATH=/api/events
VITE_PROGRAM_PATH=/api/program
VITE_REGISTER_PATH=/api/register
VITE_REGISTRATIONS_PATH=/api/registrations
VITE_ANALYTICS_PATH=/api/analytics
